datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id           String   @id @default(uuid())
  firebaseUid  String?  @unique // For future integration or auth provider
  email        String   @unique
  displayName  String
  role         String   @default("citizen") // government, contractor, citizen
  organization String?

  // Relations
  projects     Project[] // Projects assigned to the contractor
  auditLogs    AuditLog[]
  madeReleaseRequests      FundReleaseRequest[] @relation("ReleaseRequestMaker")
  checkedReleaseRequests   FundReleaseRequest[] @relation("ReleaseRequestChecker")
  approvedReleaseRequests  FundReleaseRequest[] @relation("ReleaseRequestApprover")

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Project {
  id                   String        @id @default(uuid())
  projectId            String        @unique // Human-readable ID (e.g., proj-001)
  name                 String
  description          String?
  totalBudget          BigInt        // In paise (1/100 INR)
  fundsReleased        BigInt        @default(0)
  location             String
  startDate            DateTime
  endDate              DateTime
  
  status               String    @default("active") // active, completed, flagged, archived
  riskScore            Float?
  riskLevel            String    @default("normal") // normal, medium, high
  completionPercentage Int       @default(0)
  blockchainProjectId  Int?

  // Relations
  contractorId         String
  contractor           User          @relation(fields: [contractorId], references: [id])
  transactions         Transaction[]
  proofs               Proof[]
  milestones           Milestone[]
  releaseRequests      FundReleaseRequest[]
  auditLogs            AuditLog[]

  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
}

model Transaction {
  id                 String   @id @default(uuid())
  projectId          String
  amount             BigInt   // In paise
  purpose            String
  releaseDate        DateTime
  blockchainTxHash   String   @unique
  status             String   @default("pending") // pending, confirmed, failed

  // Relations
  project            Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  releaseRequest     FundReleaseRequest?

  createdAt          DateTime @default(now())
}

model Proof {
  id          String   @id @default(uuid())
  projectId   String
  fileName    String
  fileType    String   // MIME type
  ipfsHash    String   @unique
  description String

  // AI features derived upon upload
  aiAnalysisCompleted   Boolean @default(false)
  flaggedAnomalies      String? // JSON string of specific anomalies found

  // Relations
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  createdAt   DateTime @default(now())
}

model Milestone {
  id                          String   @id @default(uuid())
  projectId                   String
  name                        String
  escrowAmount                BigInt
  requiredProofCount          Int      @default(0)
  requiredCompletionPercentage Int     @default(0)
  status                      String   @default("pending") // pending, approved, completed

  project                     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  releaseRequests             FundReleaseRequest[]

  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt
}

model FundReleaseRequest {
  id             String   @id @default(uuid())
  projectId      String
  milestoneId    String?
  amount         BigInt
  purpose        String
  status         String   @default("pending_checker") // pending_checker, pending_approver, rejected, executed

  makerId        String
  checkerId      String?
  approverId     String?
  rejectionReason String?

  blockchainTxHash String?
  transactionId    String? @unique

  project        Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  milestone      Milestone? @relation(fields: [milestoneId], references: [id], onDelete: SetNull)
  maker          User      @relation("ReleaseRequestMaker", fields: [makerId], references: [id])
  checker        User?     @relation("ReleaseRequestChecker", fields: [checkerId], references: [id])
  approver       User?     @relation("ReleaseRequestApprover", fields: [approverId], references: [id])
  transaction    Transaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model AuditLog {
  id          String   @id @default(uuid())
  actorId     String?
  projectId   String?
  action      String
  entityType  String
  entityId    String
  metadata    String?

  actor       User?    @relation(fields: [actorId], references: [id], onDelete: SetNull)
  project     Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)

  createdAt   DateTime @default(now())
}
