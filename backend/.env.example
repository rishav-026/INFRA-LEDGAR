PORT=4000
# Free local setup (SQLite)
DATABASE_URL="file:./dev.db"
JWT_SECRET="dev-super-secret-jwt-key"

# Optional: Pinata / IPFS (free tier available). Leave empty to use mock CID mode.
PINATA_API_KEY=""
PINATA_SECRET_API_KEY=""

# Optional: Polygon Blockchain (Amoy testnet is free). Leave empty to use mock tx mode.
POLYGON_RPC_URL="https://rpc-amoy.polygon.technology/"
CONTRACT_ADDRESS=""
PRIVATE_KEY="" # Dev wallet for demo

# Optional: Gemini API key. If omitted, heuristic AI fallback is used.
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.0-flash-lite"
GEMINI_MAX_REQUESTS_PER_DAY=8
GEMINI_MIN_REQUEST_INTERVAL_MS=900000
GEMINI_QUOTA_COOLDOWN_MS=21600000

# Background risk refresh interval
AI_CRON_INTERVAL_HOURS=6
